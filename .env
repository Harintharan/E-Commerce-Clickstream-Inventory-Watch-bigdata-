# ============================================================================
# E-Commerce Clickstream Inventory Watch - Environment Configuration
# ============================================================================

# ============================================================================
# APPLICATION ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO

# ============================================================================
# KAFKA CONFIGURATION
# ============================================================================
KAFKA_BOOTSTRAP_SERVERS=kafka:29092
KAFKA_TOPIC=clickstream_topic
KAFKA_CONSUMER_GROUP=clickstream_consumer_group
KAFKA_CONNECT_RETRY_ATTEMPTS=30
KAFKA_CONNECT_RETRY_DELAY=5

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
DB_HOST=postgres-db
DB_PORT=5432
DB_USER=airflow
DB_PASSWORD=airflow
DB_NAME=clickstream_db
DB_CONNECTION_TIMEOUT=10

# ============================================================================
# PRODUCER CONFIGURATION
# ============================================================================
# Batch settings
BATCH_SIZE=25
BATCH_INTERVAL_SECONDS=1

# Product and user configuration
NUM_PRODUCTS=20
NUM_USERS=50

# Anomaly/Flash Sale configuration
ANOMALY_VIEW_THRESHOLD=100
ANOMALY_PURCHASE_THRESHOLD=5

# ============================================================================
# STREAM PROCESSOR CONFIGURATION
# ============================================================================
# Window configuration (must match producer timing)
WINDOW_DURATION=10 minutes
SLIDING_INTERVAL=1 minute
WATERMARK_DELAY=30 seconds
WINDOW_DURATION_MINUTES=10
SLIDING_INTERVAL_MINUTES=1

# Flash Sale detection thresholds
FLASH_SALE_VIEW_THRESHOLD=100
FLASH_SALE_PURCHASE_THRESHOLD=5

# Checkpoint and batch settings
CHECKPOINT_DIR=/app/checkpoint
FALLBACK_FLUSH_BATCH_SIZE=100
FALLBACK_EVIDENCE_INTERVAL=25

# ============================================================================
# AIRFLOW CONFIGURATION
# ============================================================================
AIRFLOW_HOME=/airflow
AIRFLOW__CORE__LOAD_EXAMPLES=False
AIRFLOW__CORE__DAGS_ARE_PAUSED_AT_CREATION=True
AIRFLOW_DAGS_FOLDER=/airflow/dags
AIRFLOW_BASE_LOG_FOLDER=/airflow/logs
AIRFLOW_PARALLELISM=4
AIRFLOW_MAX_ACTIVE_RUNS_PER_DAG=2

# DAG schedule and timing
AIRFLOW_DAG_SCHEDULE_INTERVAL=0 23 * * *
AIRFLOW_DAG_START_DATE=2024-01-01

# Report configuration
REPORT_DIR=/airflow/logs/reports
REPORT_RETENTION_DAYS=30

# ============================================================================
# SMTP CONFIGURATION (For Email Reports)
# ============================================================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=yarlhubgof@gmail.com
SMTP_PASSWORD="thla jjyx ryij qlfn"
REPORT_RECIPIENT=thevarasathayanan@gmail.com
REPORT_SENDER=yarlhubgof@gmail.com

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_FILE=/app/logs/clickstream.log
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_FLASH_SALE_DETECTION=True
ENABLE_ANOMALY_INJECTION=True
ENABLE_DATA_QUALITY_CHECKS=True

# ============================================================================
# MONITORING CONFIGURATION
# ============================================================================
METRICS_ENABLED=True
HEALTH_CHECK_INTERVAL=30

# ============================================================================
# EVENT TYPES (Comma-separated)
# ============================================================================
EVENT_TYPES=view,add_to_cart,purchase

# ============================================================================
# SPARK CONFIGURATION
# ============================================================================
SPARK_APP_NAME=ClickstreamProcessor
SPARK_SQL_STREAMING_SCHEMA_INFERENCE=true
SPARK_LOG_LEVEL=ERROR
